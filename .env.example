# Convex deployment (set by `bunx convex dev`)
# CONVEX_DEPLOYMENT=dev:adjective-animal-123

# Convex URLs (Next.js client + Better Auth bridge)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
# Optional: omit to auto-derive from NEXT_PUBLIC_CONVEX_URL (.cloud → .site)
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Local site URL (optional; used in docs for consistency)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Convex Dashboard (per deployment), not Vercel ---
# SITE_URL=https://your-app.vercel.app   (same URL users see; required for Better Auth baseURL)
# OPENROUTER_API_KEY=sk-or-...
